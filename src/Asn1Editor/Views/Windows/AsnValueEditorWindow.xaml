<Window x:Class="SysadminsLV.Asn1Editor.Views.Windows.AsnValueEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:SysadminsLV.Asn1Editor.API.ViewModel"
        xmlns:cmd="clr-namespace:SysadminsLV.WPF.OfficeTheme.Toolkit.Commands;assembly=Wpf.OfficeTheme"
        xmlns:wpf="clr-namespace:SysadminsLV.Asn1Editor.API.Utils.WPF"
        xmlns:c="clr-namespace:SysadminsLV.Asn1Editor.Controls;assembly=SysadminsLV.Asn1Editor.Controls"
        cmd:DialogCloser.DialogResult="{Binding DialogResult}"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:AsnValueEditorVM}"
        Title="ASN.1 Value Editor"
        Height="420"
        Width="600"
        Icon="/Views/Images/Menu/edit_16x16.png"
        FontSize="{Binding UserSettings.FontSize, Mode=OneTime}"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="{StaticResource LightBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataTemplates for each editor type -->
        <DataTemplate x:Key="ReadOnlyTemplate">
            <TextBox Text="This node cannot be edited (constructed, NULL, or containing types)."
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     BorderThickness="0"
                     Background="Transparent"/>
        </DataTemplate>

        <DataTemplate x:Key="HexEditorTemplate">
            <c:AsnHexValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                                 InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                                 Result="{Binding Result, Mode=OneWayToSource}"
                                 ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <DataTemplate x:Key="BooleanEditorTemplate">
            <c:AsnBooleanValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                                     InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                                     Result="{Binding Result, Mode=OneWayToSource}"
                                     ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <DataTemplate x:Key="OidEditorTemplate">
            <c:AsnOidValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                            InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                            Result="{Binding Result, Mode=OneWayToSource}"
                            ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <DataTemplate x:Key="UtcTimeTemplate">
            <c:AsnUtcTimeValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                                     InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                                     Result="{Binding Result, Mode=OneWayToSource}"
                                     ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <DataTemplate x:Key="GeneralizedTimeTemplate">
            <c:AsnGeneralizedTimeValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                                            InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                                            Result="{Binding Result, Mode=OneWayToSource}"
                                            ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <DataTemplate x:Key="StringEditorTemplate">
            <c:AsnVariantValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                                     InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                                     Result="{Binding Result, Mode=OneWayToSource}"
                                     ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <DataTemplate x:Key="BitStringTemplate">
            <c:AsnBitStringValueEditor d:DataContext="{d:DesignInstance vm:AsnValueEditorContext}"
                                       InputValue="{Binding OriginalEncodedValue, Mode=OneTime}"
                                       Result="{Binding Result, Mode=OneWayToSource}"
                                       ValidateCommand="{Binding ValidateCommand, Mode=OneWayToSource}"/>
        </DataTemplate>

        <!-- DataTemplateSelector -->
        <wpf:AsnValueEditorTemplateSelector x:Key="EditorTemplateSelector"
                                            ReadOnlyTemplate="{StaticResource ReadOnlyTemplate}"
                                            HexTemplate="{StaticResource HexEditorTemplate}"
                                            BooleanTemplate="{StaticResource BooleanEditorTemplate}"
                                            OidTemplate="{StaticResource OidEditorTemplate}"
                                            UtcTimeTemplate="{StaticResource UtcTimeTemplate}"
                                            GeneralizedTimeTemplate="{StaticResource GeneralizedTimeTemplate}"
                                            StringTemplate="{StaticResource StringEditorTemplate}"
                                            BitStringTemplate="{StaticResource BitStringTemplate}"/>
    </Window.Resources>
    <DockPanel>
        <!-- Tag Details Section -->
        <HeaderedContentControl DockPanel.Dock="Top"
                                Header="Tag Details"
                                BorderThickness="0">
            <TextBox BorderThickness="0"
                     Text="{Binding TagDetails, Mode=OneWay}"
                     FontFamily="Consolas"
                     FontWeight="Bold"
                     MinLines="5"
                     VerticalScrollBarVisibility="Auto"
                     IsReadOnly="True"/>
        </HeaderedContentControl>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom"
                   FontSize="{Binding UserSettings.FontSize}">
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Ok"
                            MinWidth="70"
                            Command="{Binding OkCommand}"
                            IsDefault="True"/>
                    <Button Content="Cancel"
                            MinWidth="70"
                            IsCancel="True"
                            Margin="10,0,10,0"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- Main Content Area -->
        <HeaderedContentControl Header="Tag Value"
                                BorderThickness="0,1,0,0">
            <DockPanel>
                <!-- Error Display -->
                <c:NotificationPanel DockPanel.Dock="Top"
                                     Visibility="{Binding EditorContext.Result.IsValid, Converter={StaticResource BooleanToVisibilityReversedConverter}, FallbackValue=Collapsed}">
                    <c:NotificationItem Kind="Danger" IsDismissable="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding EditorContext.Result.ErrorMessage, FallbackValue={x:Null}}"
                                       Foreground="Black"/>
                            <TextBlock Margin="3,0">
                                <Hyperlink Command="{Binding EditorContext.ValidateCommand, FallbackValue={x:Null}}">Refresh</Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </c:NotificationItem>
                </c:NotificationPanel>
                <!-- Mode Selector -->
                <StackPanel DockPanel.Dock="Top"
                            Visibility="{Binding EditorContext.IsHexSwitchEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                            Orientation="Horizontal"
                            MinHeight="30"
                            Margin="10,5">
                    <CheckBox Content="Force Hex Mode" 
                              IsChecked="{Binding ForceHexMode}"
                              VerticalAlignment="Center"/>
                </StackPanel>
                <!-- Separator -->
                <Border DockPanel.Dock="Top"
                        Visibility="{Binding EditorContext.IsHexSwitchEnabled, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="0,1,0,0"/>

                <!-- Dynamic Editor Content -->
                <ContentControl Content="{Binding EditorContext}"
                                ContentTemplateSelector="{StaticResource EditorTemplateSelector}"/>
            </DockPanel>
        </HeaderedContentControl>
    </DockPanel>
</Window>
